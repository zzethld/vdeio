{
  "name": "vdeio-client",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist/electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build && tsc -p tsconfig.electron.json",
    "preview": "vite preview",
    "electron:dev": "node electron-dev.mjs",
    "electron:build": "npm run build && electron-builder",
    "typecheck": "vue-tsc --noEmit && tsc -p tsconfig.electron.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "mqtt": "^5.0.0",
    "pinia": "^2.2.0",
    "shaka-player": "^4.0.0",
    "vue": "^3.5.0",
    "vue-router": "^4.4.0"
  },
  "devDependencies": {
    "@pinia/testing": "^0.1.7",
    "@vitejs/plugin-vue": "^5.1.0",
    "@vue/test-utils": "^2.4.11",
    "electron": "^32.3.3",
    "electron-builder": "^24.13.0",
    "jsdom": "^29.1.1",
    "ts-node": "^10.9.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vitest": "^4.1.8",
    "vue-tsc": "^2.1.0"
  }
}
