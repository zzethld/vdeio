# ============================================
# 连锁门店视频管理系统 — 服务端环境变量配置
# ============================================

# ---------- 服务配置 ----------
PORT=3000
NODE_ENV=production

# ---------- MySQL ----------
DB_HOST=mysql
DB_PORT=3306
DB_NAME=vdeio
DB_USER=root
DB_PASSWORD=changeme

# ---------- Redis ----------
REDIS_HOST=redis
REDIS_PORT=6379

# ---------- MinIO 对象存储 ----------
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET_ORIGINAL=video-original
MINIO_BUCKET_ENCRYPTED=video-encrypted

# ---------- JWT ----------
JWT_SECRET=changeme-random-string-at-least-32-chars
JWT_EXPIRES_IN=2h
JWT_REFRESH_EXPIRES_IN=7d

# ---------- 钉钉开放平台 ----------
# 登录 https://open-dev.dingtalk.com 创建应用获取
DINGTALK_APP_KEY=
DINGTALK_APP_SECRET=
# 扫码登录回调地址（必须与钉钉开放平台应用配置中的回调 URI 一致）
DINGTALK_REDIRECT_URI=http://localhost:3000/api/v1/auth/dingtalk/callback
# 告警机器人 Webhook（可选）
DINGTALK_ALERT_WEBHOOK=

# ---------- FFmpeg 视频加密 ----------
FFMPEG_PATH=ffmpeg
# 主密钥（32 字节十六进制字符串），用于加密 AES-128 HLS 密钥
MASTER_KEY=changeme-32-byte-hex-string

# ---------- MQTT (EMQX) ----------
MQTT_BROKER_URL=mqtt://emqx:1883
MQTT_USERNAME=vdeio-server
MQTT_PASSWORD=changeme

# ---------- 管理员默认账号 ----------
ADMIN_DEFAULT_USERNAME=admin
ADMIN_DEFAULT_PASSWORD=changeme
